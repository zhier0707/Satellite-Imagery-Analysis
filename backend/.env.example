# ============================================================
# 后端环境变量模板 - 复制为 .env 后填入真实值
# 真实 .env 已被 .gitignore 排除,不会提交到仓库
# ============================================================

# 高德 Web 服务 Key - 后端 LBS API (POI/地理编码/路径规划/天气/...) 鉴权用
# 服务平台必须选 "Web 服务",IP 白名单建议填本机 + 生产服务器公网 IP
# amap-lbs-skill 读取此变量(也可写成 AMAP_API_KEY,personal-map skill 兼容)
AMAP_WEBSERVICE_KEY=请填入你的_Web服务_Key
AMAP_API_KEY=同上

# ==================== 数据库 ====================
# 默认: SQLite ./data/app.db
# 生产建议: postgresql+psycopg2://user:pass@host:5432/dbname
# SQLALCHEMY_DATABASE_URL=sqlite:///./data/app.db

# ==================== JWT 鉴权 ====================
# 不填则首次启动自动生成 32 字节随机串到 data/.jwt_secret
# JWT_SECRET=your-32-byte-secret

# ==================== CORS 允许源(逗号分隔) ====================
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-prod-domain
